# TT-Lang trace statistics tool (ttlang-sim-stats)
#
# Derives simulator statistics from a JSON Lines trace file produced by
# ttlang-sim --trace (tensor / pipe / DFB summary tables).
# Usage: ttlang-sim-stats trace.jsonl

PYTHON="${PYTHON:-python}"

exec "$PYTHON" -m sim_stats "$@"
