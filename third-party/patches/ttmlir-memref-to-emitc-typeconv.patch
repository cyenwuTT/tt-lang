@@ -165,6 +165,30 @@ static bool mayHaveRuntimeCBArgs(func::FuncOp funcOp) {
   return !argSpec || !argSpec.getRtArgs().empty();
 }

+static bool isMemRefTypeLegalForEmitC(MemRefType memRefType) {
+  if (!memRefType.hasStaticShape() || !memRefType.getLayout().isIdentity() ||
+      memRefType.getRank() == 0) {
+    return false;
+  }
+
+  for (int64_t dimension : memRefType.getShape()) {
+    if (dimension == 0) {
+      return false;
+    }
+  }
+  return true;
+}
+
+static Value materializeAsUnrealizedCast(OpBuilder &builder, Type resultType,
+                                         ValueRange inputs, Location loc) {
+  if (inputs.size() != 1) {
+    return Value();
+  }
+
+  return UnrealizedConversionCastOp::create(builder, loc, resultType, inputs)
+      .getResult(0);
+}
+
 namespace {
 struct TTKernelToEmitCConversionState {
   llvm::DenseMap<Block *, llvm::StringSet<>> cbDeclarations;
@@ -461,6 +485,21 @@ public:
     addConversion([ctx](Float16Type type) -> Type {
       return IntegerType::get(ctx, 16, IntegerType::Unsigned);
     });
+    addConversion([&](MemRefType memRefType) -> std::optional<Type> {
+      if (!isMemRefTypeLegalForEmitC(memRefType)) {
+        return {};
+      }
+
+      Type convertedElementType = convertType(memRefType.getElementType());
+      if (!convertedElementType) {
+        return {};
+      }
+
+      return emitc::ArrayType::get(memRefType.getShape(),
+                                   convertedElementType);
+    });
+    addSourceMaterialization(materializeAsUnrealizedCast);
+    addTargetMaterialization(materializeAsUnrealizedCast);
   }
 };
 } // namespace
